  <script>
    // Nav scroll + logo colour switch
    const nav = document.getElementById('mainNav');
    const logoText  = document.getElementById('logoText');
    const logoLine  = document.getElementById('logoLine');
    const drips     = ['logoDrip1','logoDrip2','logoDrip3'].map(id => document.getElementById(id));

    window.addEventListener('scroll', () => {
      const past = window.scrollY > 60;
      nav.classList.toggle('scrolled', past);
      const c = past ? '#c4703a' : '#fffef9';
      if (logoText) logoText.setAttribute('fill', c);
      if (logoLine) logoLine.setAttribute('stroke', c);
      drips.forEach(d => { if (d) d.setAttribute('stroke', c); });
    }, { passive: true });

    // Scroll reveal
    const revealEls = document.querySelectorAll('.reveal');
    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
      });
    }, { threshold: 0.12 });
    revealEls.forEach(el => obs.observe(el));

    // Hero photo scroll-driven zoom + blur — icing distortion effect
    const heroPhoto = document.getElementById('heroPhoto');
    window.addEventListener('scroll', () => {
      const heroH = document.getElementById('hero').offsetHeight;
      const p = Math.min(1, Math.max(0, (window.scrollY - heroH * 0.1) / (heroH * 0.8)));
      if (!heroPhoto) return;
      const scale      = 1 + p * 0.1;
      const blurVal    = p * 10;
      const brightness = 1 + p * 0.06;
      heroPhoto.style.transform = `scale(${scale})`;
      heroPhoto.style.filter    = `blur(${blurVal}px) brightness(${brightness}) saturate(${1 + p * 0.15})`;
    }, { passive: true });
  </script>

